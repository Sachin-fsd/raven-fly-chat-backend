NODE_ENV=development
PORT=4000

# Mongo
MONGO_URI=mongodb://localhost:27017/chatapp

# AstraDB
ASTRA_DB_API_ENDPOINT=https://your-db-id-region.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:xxxxxx
ASTRA_DB_KEYSPACE=default_keyspace

# Redis
REDIS_URL=redis://localhost:6379
# Set to "true" if your Redis provider requires TLS (e.g. Upstash) even
# when the URL uses a plain redis:// scheme.
REDIS_TLS=false

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_CHAT_QUEUE=chat_messages_queue

# Centrifugo — running locally on its default port.
# CENTRIFUGO_API_URL MUST include the /api suffix — Centrifugo's HTTP API
# lives at /api/*, not at the server root (a bare host:port will 404).
CENTRIFUGO_API_URL=http://localhost:8000/api
CENTRIFUGO_API_KEY=local-dev-api-key
# Must match `client.token.hmac_secret_key` in centrifugo/config.json exactly.
CENTRIFUGO_TOKEN_SECRET=local-dev-token-secret-change-me

# Auth
JWT_ACCESS_SECRET=super-secret-access-key-change-me
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000
